{:itonami.blueprint/id "cloud-itonami-isic-6312"
 :itonami.blueprint/name "Web portals — third-party content aggregation and curation"
 :itonami.blueprint/isic-rev4 "6312"
 :itonami.blueprint/domain :media/web-portal
 :itonami.blueprint/license "AGPL-3.0-or-later"
 :itonami.blueprint/social-impact [:content-provenance :license-compliance :sponsorship-disclosure]
 :itonami.blueprint/governor :portal-governor
 :itonami.blueprint/robotics false
 :itonami.blueprint/required-technologies [:identity :audit-ledger]
 :itonami.blueprint/status :public-oss
