{:paths ["src"]
 ;; langgraph brings langchain transitively (both zero-/single-dep, all
 ;; .cljc → portable to JVM / SCI / ClojureScript / GraalVM). Both live in
 ;; the kotoba-lang org of this workspace (kotoba wasm → clojurewasm →
 ;; ClojureScript → nbb runtime priority, CLAUDE.md).
 :deps {io.github.kotoba-lang/langgraph
        {:local/root "../../kotoba-lang/langgraph"}}
 :aliases
 {;; offline workspace dev — pin transitive langchain to local checkout
  :dev {:override-deps
        {io.github.kotoba-lang/langchain
         {:local/root "../../kotoba-lang/langchain"}}}
  ;; clojure -M:dev:run  → drive the demo through one OperationActor
  :run {:main-opts ["-m" "portal.sim"]}
  ;; clojure -M:dev:render-html [out-file] → regenerate docs/samples/operator-console.html
  ;; through the real actor (flagship checklist item 2, ADR-2607189300 Wave5 seq 6+).
  :render-html {:main-opts ["-m" "portal.render-html"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; OPTIONAL -- pulls in cloud-itonami-isic-6311 (market-data actor) for
  ;; `portal.marketdata-bridge` and its test only. `portal.*` core never
  ;; needs this; `clojure -M:dev:test` (no :market-data) stays green
  ;; without cloud-itonami-isic-6311 checked out at all. `:main-opts` here
  ;; must come LAST on the command line to win over :test's (aliases don't
  ;; merge :main-opts, the last-selected alias defining it wins) --
  ;; `clojure -M:dev:test:market-data`, not `:market-data:dev:test`.
  :market-data {:extra-paths ["test-market-data"]
                :extra-deps {io.github.cloud-itonami/cloud-itonami-isic-6311
                             {:local/root "../../cloud-itonami/cloud-itonami-isic-6311"}
                             io.github.cognitect-labs/test-runner
                             {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
                :main-opts ["-m" "cognitect.test-runner" "-d" "test" "-d" "test-market-data"]}
  ;; static analysis — clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
